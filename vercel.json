{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/status/edit",
      "dest": "/status/edit.html"
    },
    {
      "src": "/status",
      "dest": "/status/index.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}